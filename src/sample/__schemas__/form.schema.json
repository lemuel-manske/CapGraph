{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "form",
  "description": "A schema representing a form component.",
  "allOf": [{ "$ref": "base" }],
  "type": "object",
  "properties": {
    "componentType": {
      "const": "form"
    },
    "title": {
      "type": "string",
      "description": "The title of the form."
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "description": "An array of field components that make up the form.",
      "items": {
        "$ref": "field"
      }
    }
  },
  "required": ["title", "fields"]
}
